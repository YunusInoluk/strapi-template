{
  "kind": "collectionType",
  "collectionName": "teams",
  "info": {
    "singularName": "team",
    "pluralName": "teams",
    "displayName": "Team Member",
    "description": "Leadership and team members shown on the About page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "bio": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "theme": {
      "type": "enumeration",
      "enum": ["dark", "light"],
      "default": "dark"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
