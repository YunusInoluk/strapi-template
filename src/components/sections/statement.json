{
  "collectionName": "components_sections_statements",
  "info": {
    "displayName": "Statement",
    "icon": "quote",
    "description": "Eyebrow + heading + body with optional side image"
  },
  "options": {},
  "attributes": {
    "eyebrow": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "layout": {
      "type": "enumeration",
      "enum": ["imageLeft", "imageRight"],
      "default": "imageRight"
    },
    "theme": {
      "type": "enumeration",
      "enum": ["dark", "light"],
      "default": "dark"
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.cta"
    }
  }
}
